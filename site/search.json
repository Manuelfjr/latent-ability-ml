---
layout: null
permalink: /search.json
---
[
{% assign docs = site.html_pages | sort: "url" %}
{% for p in docs %}
{
  "title": {{ p.title | default: site.title | jsonify }},
  "eyebrow": {{ p.eyebrow | default: "" | jsonify }},
  "lead": {{ p.lead | default: "" | jsonify }},
  "url": {{ p.url | relative_url | jsonify }},
  "content": {{ p.content | markdownify | strip_html | normalize_whitespace | jsonify }}
}{% unless forloop.last %},{% endunless %}
{% endfor %}
]
